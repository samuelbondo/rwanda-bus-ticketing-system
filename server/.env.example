# Application
NODE_ENV=development
PORT=5000

# Database — Railway PostgreSQL (public URL for local dev)
DATABASE_URL="postgresql://postgres:nQytSCkchpHRAFUNSUMdnGyByXvuwFQV@${{RAILWAY_TCP_PROXY_DOMAIN}}:${{RAILWAY_TCP_PROXY_PORT}}/railway"

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_16_chars
