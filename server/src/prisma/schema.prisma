generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  CUSTOMER
  AGENT
  ADMIN
}

enum ScheduleStatus {
  SCHEDULED
  DEPARTED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  USED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MOMO
  CARD
  CASH
}

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  password             String
  role                 Role      @default(CUSTOMER)
  phone                String?
  avatarUrl            String?
  isActive             Boolean   @default(true)
  passwordResetToken   String?
  passwordResetExpiry  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  bookings      Booking[]
  cancellations Cancellation[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Bus {
  id          String    @id @default(uuid())
  name        String
  plateNumber String    @unique
  capacity    Int
  imageUrl    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  seats     Seat[]
  schedules Schedule[]

  @@map("buses")
}

model Route {
  id          String    @id @default(uuid())
  name        String
  origin      String
  destination String
  distanceKm  Decimal?
  basePrice   Decimal
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  stops     RouteStop[]
  schedules Schedule[]

  @@map("routes")
}

model RouteStop {
  id              String   @id @default(uuid())
  routeId         String
  name            String
  stopOrder       Int
  priceFromOrigin Decimal
  createdAt       DateTime @default(now())

  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@map("route_stops")
}

model Schedule {
  id             String         @id @default(uuid())
  routeId        String
  busId          String
  departureTime  DateTime
  arrivalTime    DateTime?
  price          Decimal
  status         ScheduleStatus @default(SCHEDULED)
  availableSeats Int
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  route    Route     @relation(fields: [routeId], references: [id])
  bus      Bus       @relation(fields: [busId], references: [id])
  bookings Booking[]

  @@map("schedules")
}

model Seat {
  id          String   @id @default(uuid())
  busId       String
  seatNumber  String
  createdAt   DateTime @default(now())

  bus      Bus       @relation(fields: [busId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([busId, seatNumber])
  @@map("seats")
}

model Booking {
  id           String        @id @default(uuid())
  userId       String
  scheduleId   String
  seatId       String
  ticketNumber String        @unique
  qrCode       String
  source       String
  destination  String
  status       BookingStatus @default(PENDING)
  totalPrice   Decimal
  bookedAt     DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  schedule     Schedule      @relation(fields: [scheduleId], references: [id])
  seat         Seat          @relation(fields: [seatId], references: [id])
  payment      Payment?
  cancellation Cancellation?

  @@map("bookings")
}

model Payment {
  id        String        @id @default(uuid())
  bookingId String        @unique
  amount    Decimal
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  reference String?
  paidAt    DateTime?
  createdAt DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Cancellation {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  cancelledBy String
  reason      String?
  cancelledAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  user    User    @relation(fields: [cancelledBy], references: [id])

  @@map("cancellations")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

enum SlideshowSource {
  CUSTOM
  BUSES
  ROUTES
}

model SlideshowConfig {
  id        String          @id @default("singleton")
  source    SlideshowSource @default(CUSTOM)
  interval  Int             @default(5000)
  updatedAt DateTime        @updatedAt

  @@map("slideshow_config")
}

model HeroSlide {
  id        String   @id @default(uuid())
  title     String
  subtitle  String?
  imageUrl  String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hero_slides")
}
